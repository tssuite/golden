{
  "name": "@tssuite/golden",
  "version": "1.0.1",
  "description": "Create golden files right within your tests",
  "homepage": "https://github.com/tssuite/golden",
  "bugs": "https://github.com/tssuite/golden/issues",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tssuite/golden.git"
  },
  "main": "dist/golden.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && tsc && node dna/scripts/copy-readme-to-dist.js",
    "test": "vitest run --coverage && pnpm run lint",
    "prebuild": "npm run test",
    "prepublishOnly": "npm run build",
    "lint": "eslint",
    "updateGoldens": "cross-env UPDATE_GOLDENS=true pnpm test"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "read-pkg": "^10.1.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^5.0.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "vitest-dom": "^0.1.1"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "peerDependencies": {
    "@rljson/json": "^0.0.21",
    "@tssuite/project-root": "0.0.17"
  }
}
